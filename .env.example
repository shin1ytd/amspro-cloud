# ============================================================
# AmsPRO 環境変数テンプレート
# このファイルを .env にコピーして値を設定する
#   cp .env.example .env
# ============================================================

# サーバーポート
PORT=8080

# PostgreSQL接続
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amspro
DB_USER=amspro
DB_PASSWORD=amspro_dev

# Cloud SQL 経由の場合（Cloud Run用）
# DB_SOCKET_PATH=/cloudsql/<PROJECT_ID>:<REGION>:<INSTANCE_NAME>
